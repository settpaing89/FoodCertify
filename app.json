{
  "expo": {
    "name": "Vett",
    "slug": "vett",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.paing.vett",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Vett uses your camera to scan product barcodes and analyze ingredient safety.",
        "NSPhotoLibraryUsageDescription": "Vett can scan barcodes from photos in your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1E"
      },
      "package": "com.paing.vett",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Vett uses your camera to scan product barcodes."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b562537f-cba6-4d95-95be-cde3491f7657"
      }
    },
    "owner": "paing89"
  }
}
